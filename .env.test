# ==============================================================================
# KASPA PULSE - TESTNET & PARITY TESTING ENVIRONMENT
# ==============================================================================
# Use a separate database to avoid corrupting production data
DATABASE_URL=postgres://postgres:password@localhost:5432/kaspa_test_db

# Point to a Testnet node (e.g., Testnet-11 or Testnet-12) to simulate live events
KASPA_RPC_URL=grpc://127.0.0.1:16210

# Use a separate Telegram Bot token for testing
TELEGRAM_BOT_TOKEN=YOUR_TEST_BOT_TOKEN_HERE

# Strict logging to catch JSON parsing or Hashrate calculation errors
RUST_LOG=debug,kaspa_pulse=trace

# Limits for safe traversal during tests
DAG_TRAVERSAL_LIMIT=800

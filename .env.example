# Telegram Bot Token (Required)
TELOXIDE_TOKEN=your_bot_token_here

# Database URL (Required for PostgreSQL/Vector)
DATABASE_URL=postgres://user:password@localhost/kaspa_db

# Admin Security PIN (Required for sensitive actions)
ADMIN_PIN=123456

# Webhook URL (Optional: If set, bot runs in Webhook mode via Axum. If empty, runs in Polling mode)
# WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_PORT=8080
